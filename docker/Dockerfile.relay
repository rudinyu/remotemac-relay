# RemoteMac relay — blind rendezvous server. Pure Python stdlib, no dependencies.
FROM python:3.12-slim

WORKDIR /app
COPY relay.py .

# Run unprivileged; the relay binds a high port (default 21118, no root needed).
RUN useradd --system --uid 10001 app
USER 10001

EXPOSE 21118
# -u: unbuffered stdout so `docker logs` is live.
ENTRYPOINT ["python3", "-u", "relay.py"]
CMD ["21118"]
